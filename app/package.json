{
  "name": "pressf-desktop",
  "version": "0.3.1",
  "private": true,
  "description": "PressF Desktop macOS app",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -p tsconfig.main.json && esbuild src/main/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/main/preload.cjs && vite build",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts src/main/projectData.test.ts",
    "test:smoke": "playwright test",
    "dist": "npm run build && electron-builder --mac dmg --arm64"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.13.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.21.5",
    "typescript": "^5.7.3",
    "vite": "^5.4.19",
    "vitest": "^2.1.9",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "dev.pressf.desktop",
    "productName": "PressF",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../pressf",
        "to": "repo/pressf"
      },
      {
        "from": "../demo-openai",
        "to": "repo/demo-openai"
      },
      {
        "from": "../demo",
        "to": "repo/demo"
      },
      {
        "from": "../pyproject.toml",
        "to": "repo/pyproject.toml"
      },
      {
        "from": "../.venv",
        "to": "repo/.venv",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false
    }
  }
}
